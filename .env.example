# ── Airtable (recommended) ─────────────────────────────────
# Create a Personal Access Token: https://airtable.com/create/tokens
# Scopes: data.records:write for the base. Use the base + table below.
AIRTABLE_PAT=
# Alias also supported:
# AIRTABLE_API_KEY=

AIRTABLE_BASE_ID=appS0Nfve0Di8jeKp
AIRTABLE_TABLE_ID=tblcpqpSso2IeAr6p

# ── Maton gateway (optional fallback if AIRTABLE_PAT is not set) ──
MATON_API_KEY=
# MATON_CONNECTION_ID=e2e40838-4a68-4916-94e4-38b4e82f513a

# ── Vercel Blob (donate form photos) ───────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY=

# ── Cron / digest (if you add those routes) ─────────────────
CRON_SECRET=
DIGEST_EMAIL_TO=

# ── Optional: Password Gate ────────────────────────────────
NEXT_PUBLIC_PASSWORD_ENABLED=false
