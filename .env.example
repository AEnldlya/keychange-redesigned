# Required — Vercel Blob (public store for instrument photos)
BLOB_READ_WRITE_TOKEN=

# Required — Airtable
AIRTABLE_BASE_ID=
AIRTABLE_API_KEY=

# Required — Resend (transactional email + daily digest)
RESEND_API_KEY=

# Required — Cron authentication
CRON_SECRET=

# Required — Daily digest recipient
DIGEST_EMAIL_TO=

# Optional — Password gate (set to "true" to enable, defaults to off)
NEXT_PUBLIC_PASSWORD_ENABLED=false

# Optional — Custom gate password (defaults to "0nestepatatime")
NEXT_PUBLIC_GATE_PASSWORD=

# Optional — Site URL (defaults to https://keychange.org)
NEXT_PUBLIC_SITE_URL=https://keychange.org
